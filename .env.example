# QuickScope Configuration
# Copy to ~/.config/quickscope/.env and fill in values.
# Never commit real credentials.

# ── GMGN API (primary data source) ──────────────────────────────
# Get a key at https://gmgn.ai/ai
# Generate an Ed25519 keypair, register the public key, paste the API key here.
GMGN_API_KEY=gmgn_solbscbaseethmonadtron

# ── Alph AI API (secondary: Twitter + WebSocket + signals) ──────
# Log into https://alph.ai, open DevTools (F12) → Application → Cookies →
# copy the `dex_cookie` value. Valid 14 days.
ALPH_DEX_COOKIE=

# ── LLM Providers (for post-mortem feature) ─────────────────────
# At least one recommended. Provider is selected in Settings.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# ── DEX Screener (tertiary, free, no auth) ──────────────────────
DEXSCREENER_BASE_URL=https://api.dexscreener.com

# ── QuickScope runtime ──────────────────────────────────────────
# SQLite database location
QUICKSCOPE_DB_PATH=~/.config/quickscope/data.db
# Log level: error | warn | info | debug | trace
QUICKSCOPE_LOG_LEVEL=info
# Data poll interval for non-WebSocket data (seconds)
QUICKSCOPE_POLL_INTERVAL=2
